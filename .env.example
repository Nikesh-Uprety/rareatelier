DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/your-db-name
SESSION_SECRET=your-session-secret-at-least-32-characters-long
NODE_ENV=development
PORT=5001

# Email (Resend - Better than Gmail for production)
# Get API key from https://resend.com/dashboard/api-keys
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your App Name

# Legacy Mailjet (for development only)
# Get credentials from https://app.mailjet.com/
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# 2FA
OTP_EXPIRY_MINUTES=10

# Uploads persistence
# For local development, you can leave this unset (defaults to `./uploads`).
# On Railway, mount a persistent volume to the container path and set `UPLOADS_DIR`
# to that same path (recommended: `/uploads`).
UPLOADS_DIR=/uploads

# S3-Compatible Storage (Tigris Storage)
# Configure for Railway deployment
S3_ENDPOINT=https://your-storage-endpoint
S3_REGION=your-storage-region
S3_BUCKET=your-storage-bucket
S3_ACCESS_KEY_ID=your-storage-access-key-id
S3_SECRET_ACCESS_KEY=your-storage-secret-access-key

# Alternative: Tigris Storage (your new bucket)
# TIGRIS_ENDPOINT=https://your-tigris-endpoint
# TIGRIS_REGION=your-tigris-region
# TIGRIS_BUCKET=your-tigris-bucket-name
# TIGRIS_STORAGE_PUBLIC_URL=https://your-bucket.t3.tigrisfiles.io
# TIGRIS_ACCESS_KEY_ID=your-tigris-access-key-id
# TIGRIS_SECRET_ACCESS_KEY=your-tigris-secret-access-key

# Sentry
SENTRY_DSN=your-sentry-dsn
VITE_SENTRY_DSN=your-vite-sentry-dsn

# Stripe (Payment Gateway — Test Mode)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook Signing Secret
# For local dev: run `stripe listen --forward-to localhost:5000/api/payments/webhook`
# For production: create webhook endpoint in Stripe Dashboard → Developers → Webhooks
#   URL: https://your-domain.com/api/payments/webhook
#   Events: checkout.session.completed, checkout.session.expired, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (used for Stripe redirect URLs in production)
APP_URL=https://your-domain.com

# Fonepay (Sandbox / Dev)
# Use a publicly reachable callback URL (for local dev, expose your app with ngrok or similar).
FONEPAY_PG_URL=https://dev-clientapi.fonepay.com
FONEPAY_PG_MERCHANT_CODE=NBQM
FONEPAY_PG_MERCHANT_SECRET=your-fonepay-merchant-secret
FONEPAY_PG_CALLBACK_URL=https://your-domain.com/api/payments/fonepay/callback
FONEPAY_DYNAMICQR_URL=https://dev-merchantapi.fonepay.com/convergentmerchantweb/api/merchant/merchantDetailsForThirdParty
FONEPAY_USERNAME=your-fonepay-merchant-username
FONEPAY_PASSWORD=your-fonepay-merchant-password
CLIENT_URL=https://your-domain.com

# Optional: allow embedding this app in specific parent sites (iframe frame-ancestors CSP)
# Comma-separated CSP source values.
# Example:
# EMBED_ALLOWED_FRAME_ANCESTORS=https://nikeshuprety.com.np,https://www.nikeshuprety.com.np,http://localhost:3000,http://127.0.0.1:3000
# EMBED_ALLOWED_FRAME_ANCESTORS=
